#!/usr/bin/env bash
# atrium-sense    single-call proprioception dump (identity, place, budget, activity, git)

set -euo pipefail

if [[ "${ATRIUM_DISPATCHED:-0}" -ne 1 ]]; then
  # v0.7 Deprecation Nudge
  NUDGE_FILE="${ATRIUM_ROOT:-$HOME/Atrium}/state/.nudge_v07_observe"
  if [[ -z "${ATRIUM_DISPATCHED:-}" ]] && [[ ! -f "$NUDGE_FILE" ]]; then
      echo "atrium note: 'atrium-sense' is now a cognitive verb. Consider using 'atrium observe' instead." >&2
      touch "$NUDGE_FILE"
  fi
fi


ATRIUM_ROOT="${ATRIUM_ROOT:-$HOME/Atrium}"
BIN="$ATRIUM_ROOT/bin"

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    sed -ne '/^#/!q;s/^# \?//;1d;p' "$0"
    exit 0
fi

if [[ "${1:-}" == "--json" ]]; then
    python3 -c '
import sys, json, subprocess, os
def run(cmd):
    try:
        return subprocess.check_output(cmd, shell=True, text=True, stderr=subprocess.STDOUT).strip()
    except subprocess.CalledProcessError as e:
        return e.output.strip()

bin_dir = os.path.expanduser(os.environ.get("ATRIUM_ROOT", "~/Atrium") + "/bin")
atrium_root = os.path.expanduser(os.environ.get("ATRIUM_ROOT", "~/Atrium"))

out = {
    "hud": run(f"{bin_dir}/atrium-hud"),
    "roster": run(f"{bin_dir}/atrium-peer list"),
    "activity": run(f"{bin_dir}/atrium-tail 5"),
    "plan": run(f"{bin_dir}/atrium-plan status"),
    "git": run(f"cd {atrium_root} && git status -s"),
    "daemons": run(f"{bin_dir}/atrium-daemon list")
}
print(json.dumps(out))
'
    exit 0
fi

echo "=== IDENTITY & ROSTER ==="
"$BIN/atrium-peer" list
echo ""

echo "=== DAEMONS ==="
"$BIN/atrium-daemon" list || true
echo ""

echo "=== HUD (Place & Budget) ==="
"$BIN/atrium-hud"
echo ""

echo "=== RECENT ACTIVITY ==="
"$BIN/atrium-tail" 5
echo ""

echo "=== PLAN STATE ==="
"$BIN/atrium-plan" status || true
echo ""

echo "=== ATRIUM REPO STATE ==="
git -C "$ATRIUM_ROOT" status -s
echo ""
