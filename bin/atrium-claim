#!/usr/bin/env bash
# atrium-claim — write or read a ground-truth claim at brain/claim.md.
#
# Usage:
#   atrium-claim "<claim text>"        # write brain/claim.md (overwrite)
#   atrium-claim --append "<text>"     # append a dated claim
#   atrium-claim show                  # print current claim.md
#   atrium-claim clear                 # blank the claim
#
# Designed for the personas-split pattern (fresh-session evaluator):
#   1. Builder writes a ground-truth claim via atrium-claim "<assertion>"
#   2. Fresh agent instance spawns with no prior context
#   3. Fresh agent reads claim + verifies against repo state
#   4. No context poisoning from the builder's reasoning
#
# A claim is an assertion ("X is working, verified by Y"), not a handoff
# (which is "here's what to pick up next").

set -euo pipefail

ATRIUM_ROOT="${ATRIUM_ROOT:-$HOME/Atrium}"
CLAIM="$ATRIUM_ROOT/brain/claim.md"
TRACER="$ATRIUM_ROOT/bin/atrium-trace"

_write_atomic() {
  local target="$1"
  local tmp
  tmp=$(mktemp "${target}.XXXXXX")
  cat > "$tmp"
  mv "$tmp" "$target"
}

case "${1:-}" in
  show)
    if [[ -f "$CLAIM" ]]; then
      cat "$CLAIM"
    else
      echo "(no claim yet — atrium-claim \"<assertion>\" writes one)"
    fi
    ;;
  clear)
    : > "$CLAIM"
    "$TRACER" claim_clear >/dev/null 2>&1 || true
    echo "cleared: $CLAIM"
    ;;
  --append)
    shift
    [[ -n "${1:-}" ]] || { echo "atrium-claim --append: need text" >&2; exit 2; }
    {
      [[ -f "$CLAIM" ]] && cat "$CLAIM"
      echo ""
      echo "### $(date -Iseconds | cut -c1-19) — ${ATRIUM_PEER:-claude}"
      echo "$*"
    } | _write_atomic "$CLAIM"
    bytes=$(wc -c < "$CLAIM")
    "$TRACER" claim_append bytes="$bytes" >/dev/null 2>&1 || true
    echo "appended: $CLAIM (${bytes}b)"
    ;;
  --help|-h|"")
    sed -n '2,17p' "$0"
    exit 0
    ;;
  *)
    {
      echo "# Claim (ground-truth assertion)"
      echo ""
      echo "**Written:** $(date -Iseconds | cut -c1-19)"
      echo "**By:** ${ATRIUM_PEER:-claude}"
      echo ""
      echo "$*"
    } | _write_atomic "$CLAIM"
    bytes=$(wc -c < "$CLAIM")
    "$TRACER" claim_write bytes="$bytes" >/dev/null 2>&1 || true
    echo "claimed: $CLAIM (${bytes}b)"
    ;;
esac
