#!/usr/bin/env bash
# atrium-cost-ingest — pull real spend + tokens from Claude Code's session
# transcripts into state/trace.jsonl. Turns the HUD from synthetic theater
# into honest proprioception.
#
# Usage:
#   atrium-cost-ingest scan            # one-shot: ingest all new messages
#                                        from all current session jsonls
#   atrium-cost-ingest scan --session <id>
#                                        # only that session
#   atrium-cost-ingest watch            # daemon: tails jsonls, ingests live
#   atrium-cost-ingest totals           # print current totals (tokens + $)
#
# Data source:
#   ~/.claude/projects/<project-slug>/<session-uuid>.jsonl
#
# Cursor:
#   state/cost-cursor.json tracks the last-ingested byte-offset per session
#   so we don't double-count.
#
# Pricing:
#   state/pricing.json (USD per million tokens per model). Override if your
#   contract price differs.

set -euo pipefail

ATRIUM_ROOT="${ATRIUM_ROOT:-$HOME/Atrium}"
TRACE="$ATRIUM_ROOT/state/trace.jsonl"
PRICING="$ATRIUM_ROOT/state/pricing.json"
CURSOR="$ATRIUM_ROOT/state/cost-cursor.json"

# Find Claude Code's projects dir (usually ~/.claude/projects/<slug>)
CC_PROJECTS="${CLAUDE_PROJECTS_DIR:-$HOME/.claude/projects}"

cmd_scan() {
  local only_session=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --session) only_session="$2"; shift 2 ;;
      *) echo "unknown: $1" >&2; exit 2 ;;
    esac
  done

  python3 - "$CC_PROJECTS" "$TRACE" "$PRICING" "$CURSOR" "$only_session" <<'PY'
import sys, os, json, glob, datetime
from pathlib import Path

projects, trace_path, pricing_path, cursor_path, only_session = sys.argv[1:6]

# Load pricing
with open(pricing_path) as f:
    pricing = json.load(f)
default_model = pricing.get("default_model", "claude-opus-4-7")
models = pricing.get("models", {})

def rate(model, key):
    return models.get(model, models[default_model])[key] / 1_000_000.0

# Load cursor: { "<session_id>": last_offset_bytes, ... }
cursor = {}
if Path(cursor_path).exists():
    try: cursor = json.loads(Path(cursor_path).read_text())
    except Exception: cursor = {}

# Walk all JSONLs under Claude's projects dir
jsonls = glob.glob(os.path.join(projects, "**", "*.jsonl"), recursive=True)
new_events = 0
for jp in jsonls:
    session_id = Path(jp).stem
    if only_session and session_id != only_session:
        continue
    last_off = cursor.get(session_id, 0)
    try:
        size = os.path.getsize(jp)
    except FileNotFoundError:
        continue
    if size <= last_off:
        continue

    # Read from cursor onwards
    with open(jp, "rb") as f:
        f.seek(last_off)
        raw = f.read()

    # If we landed mid-line (cursor was set when a partial line was flushed),
    # skip up to first newline so the rest parses cleanly.
    if last_off > 0 and not raw.startswith(b"\n"):
        pass  # our line boundaries should already be clean because cursor was updated only at a full-line position below

    buf = b""
    # Split on \n and keep a tail buffer if last chunk didn't end in \n
    lines = raw.split(b"\n")
    if raw.endswith(b"\n"):
        tail = b""
    else:
        tail = lines[-1]
        lines = lines[:-1]

    new_off = last_off
    for line in lines:
        new_off += len(line) + 1  # +1 for the newline
        line = line.strip()
        if not line: continue
        try:
            d = json.loads(line)
        except Exception:
            continue
        if d.get("type") != "assistant":
            continue
        msg = d.get("message", {}) or {}
        usage = msg.get("usage") or {}
        if not usage:
            continue
        model = msg.get("model", default_model)
        in_tok   = usage.get("input_tokens", 0) or 0
        out_tok  = usage.get("output_tokens", 0) or 0
        cache_r  = usage.get("cache_read_input_tokens", 0) or 0
        cache_c  = usage.get("cache_creation_input_tokens", 0) or 0
        # breakdown of cache creation between 5m / 1h if present
        cc = usage.get("cache_creation") or {}
        cc_5m = cc.get("ephemeral_5m_input_tokens", 0) or 0
        cc_1h = cc.get("ephemeral_1h_input_tokens", 0) or 0
        # if the breakdown totals less than cache_c, dump the remainder as 5m (safe default)
        unaccounted = cache_c - (cc_5m + cc_1h)
        if unaccounted > 0:
            cc_5m += unaccounted

        cost_usd = (
            in_tok  * rate(model, "input")
            + out_tok * rate(model, "output")
            + cache_r * rate(model, "cache_read")
            + cc_5m  * rate(model, "cache_write_5m")
            + cc_1h  * rate(model, "cache_write_1h")
        )

        # Event timestamp: prefer the session message's own timestamp if present,
        # otherwise now.
        ts = d.get("timestamp") or datetime.datetime.now().astimezone().isoformat(timespec="seconds")

        event = {
            "ts": ts,
            "kind": "tool",
            "tool": "claude",
            "model": model,
            "cost_usd": round(cost_usd, 6),
            "tokens_in":        in_tok,
            "tokens_out":       out_tok,
            "tokens_cache_read":  cache_r,
            "tokens_cache_write_5m": cc_5m,
            "tokens_cache_write_1h": cc_1h,
            "session": session_id,
        }
        with open(trace_path, "a") as tf:
            tf.write(json.dumps(event, separators=(",", ":"), ensure_ascii=False) + "\n")
        new_events += 1

    cursor[session_id] = new_off

# Save cursor atomically
tmp = cursor_path + ".tmp"
Path(tmp).write_text(json.dumps(cursor, indent=2))
Path(tmp).replace(cursor_path)

print(f"ingested {new_events} events across {len(cursor)} sessions")
PY
}

cmd_watch() {
  echo "atrium-cost-ingest watch: polling every 5s. Ctrl-C to stop."
  while true; do
    cmd_scan "$@" >/dev/null 2>&1 || true
    sleep 5
  done
}

cmd_totals() {
  python3 - "$TRACE" <<'PY'
import json, sys, datetime
from collections import Counter

path = sys.argv[1]
today = datetime.date.today().isoformat()
total_cost = 0.0
day_cost = 0.0
total_in = total_out = 0
by_model = Counter()
if not __import__("os").path.exists(path):
    print("(no trace)")
    raise SystemExit
with open(path) as f:
    for ln in f:
        try: d = json.loads(ln)
        except: continue
        if d.get("kind") != "tool" or not isinstance(d.get("cost_usd"), (int,float)):
            continue
        c = d["cost_usd"]
        total_cost += c
        if d.get("ts","").startswith(today):
            day_cost += c
        total_in  += d.get("tokens_in", 0) or 0
        total_out += d.get("tokens_out", 0) or 0
        m = d.get("model","?")
        by_model[m] += c
print(f"totals across trace.jsonl:")
print(f"  all-time cost : ${total_cost:.4f}")
print(f"  today's cost  : ${day_cost:.4f}")
print(f"  input tokens  : {total_in:,}")
print(f"  output tokens : {total_out:,}")
print(f"  by model:")
for m, c in by_model.most_common():
    print(f"    {m}: ${c:.4f}")
PY
}

case "${1:-}" in
  scan)    shift; cmd_scan   "$@" ;;
  watch)   shift; cmd_watch  "$@" ;;
  totals)  shift; cmd_totals ;;
  ""|help|--help|-h) sed -n '2,17p' "$0" ;;
  *) echo "atrium-cost-ingest: unknown subcommand: ${1:-}" >&2; exit 2 ;;
esac
