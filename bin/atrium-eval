#!/usr/bin/env bash
# atrium-eval — spawn a fresh clean-context evaluator against a claim.
#
# Usage:
#   atrium eval <claim-file>
#
# Evaluates a ground-truth claim using a fresh agent instance to prevent
# context poisoning.

set -euo pipefail

if [[ "${ATRIUM_DISPATCHED:-0}" -ne 1 ]]; then
  # v0.7 Deprecation Nudge
  NUDGE_FILE="${ATRIUM_ROOT:-$HOME/Atrium}/state/.nudge_v07_eval"
  if [[ ! -f "$NUDGE_FILE" ]]; then
      echo "atrium note: 'atrium-fresh-eval' is a cognitive verb. Consider using 'atrium eval' instead." >&2
      touch "$NUDGE_FILE"
  fi
fi

ATRIUM_ROOT="${ATRIUM_ROOT:-$HOME/Atrium}"

[[ $# -ge 1 ]] || { echo "Usage: atrium eval <claim-file>" >&2; exit 2; }
CLAIM_FILE="$1"
[[ -f "$CLAIM_FILE" ]] || { echo "atrium eval: file not found: $CLAIM_FILE" >&2; exit 1; }

CLAIM_TEXT=$(cat "$CLAIM_FILE")

PROMPT="You are a fresh, clean-context evaluator agent. Your job is to verify the following claim against the ground truth of the workspace.
You must use your tools to inspect the repository, read files, and verify the claim. Do not rely on any prior context.
Output a clear Pass/Fail judgement along with your reasoning.

CLAIM TO EVALUATE:
$CLAIM_TEXT"

echo "Spawning fresh evaluator for $CLAIM_FILE..."
exec claude -p "$PROMPT" < /dev/null
